{
  "manifest_version": 3,
  "name": "Self Update Test Extension",
  "description": "Minimal extension to validate managed self-updates from GitHub-hosted artifacts.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "update_url": "https://example.com/updates.xml",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Self Update Test",
    "default_popup": "popup.html"
  }
}
